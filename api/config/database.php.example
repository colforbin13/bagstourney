<?php
// api/config/database.php.example
// Example database config — DO NOT commit real credentials. Copy this file to api/config/database.php
// and fill with your environment values, or set the environment variables described below.

/*
Option A (recommended): use environment variables (example for Apache/NGINX):

export BB_DB_HOST="127.0.0.1:3306"
export BB_DB_NAME="beanbag_tournament"
export BB_DB_USER="your_db_user"
export BB_DB_PASS="your_db_password"
export BB_JWT_SECRET="a_long_random_string_here"

Option B (development): copy this file and set values directly (not recommended for production).
*/

// Placeholder values — replace when creating api/config/database.php locally
$DB_HOST = '127.0.0.1:3306';
$DB_NAME = 'beanbag_tournament';
$DB_USER = 'dbuser';
$DB_PASS = 'your_db_password_here';
$JWT_SECRET = 'replace_with_a_secure_random_value';

// TTL for JWT in seconds (default 8 hours)
define('JWT_EXPIRY', 3600 * 8);

// When using this example file directly, define constants expected by the app
define('DB_HOST', $DB_HOST);
define('DB_NAME', $DB_NAME);
define('DB_USER', $DB_USER);
define('DB_PASS', $DB_PASS);
define('JWT_SECRET', $JWT_SECRET);

function getDB(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $dsn = "mysql:host=" . DB_HOST . ";dbname=" . DB_NAME . ";charset=utf8mb4";
        $pdo = new PDO($dsn, DB_USER, DB_PASS, [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES => false,
        ]);
    }
    return $pdo;
}

?>